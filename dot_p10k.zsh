  typeset -g POWERLEVEL9K_OS_ICON_REDHAT_CONTENT_EXPANSION="󱄛"
  typeset -g POWERLEVEL9K_OS_ICON_POP_CONTENT_EXPANSION=""

  ##################################[ context: user@hostname ]##################################
