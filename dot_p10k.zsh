  typeset -g POWERLEVEL9K_PYTHON_BACKGROUND=$blue
  typeset -g POWERLEVEL9K_PYTHON_VISUAL_IDENTIFIER_EXPANSION=''
  
  # ASDF Python fallback
  typeset -g POWERLEVEL9K_ASDF_PYTHON_FOREGROUND=$fg0
  typeset -g POWERLEVEL9K_ASDF_PYTHON_BACKGROUND=$blue
  typeset -g POWERLEVEL9K_ASDF_PYTHON_VISUAL_IDENTIFIER_EXPANSION=''

  ################################ Contexts ################################
  # docker_context
  typeset -g POWERLEVEL9K_DOCKER_CONTEXT_FOREGROUND='#83a598'
  typeset -g POWERLEVEL9K_DOCKER_CONTEXT_BACKGROUND=$bg3
  typeset -g POWERLEVEL9K_DOCKER_CONTEXT_VISUAL_IDENTIFIER_EXPANSION=''

  # conda (anaconda)
  typeset -g POWERLEVEL9K_ANACONDA_FOREGROUND='#83a598'
  typeset -g POWERLEVEL9K_ANACONDA_BACKGROUND=$bg3
  typeset -g POWERLEVEL9K_ANACONDA_CONTENT_EXPANSION='${${${${CONDA_PROMPT_MODIFIER#\(}% }%\)}:-${CONDA_PREFIX:t}}'

  ####################################[ time: current time ]####################################
  typeset -g POWERLEVEL9K_TIME_FOREGROUND=$fg0
